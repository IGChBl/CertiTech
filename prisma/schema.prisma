generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleCode {
  CLIENT
  TECHNICIAN
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ClientVerificationStatus {
  PENDING
  BASIC_VERIFIED
  VERIFIED
  REJECTED
}

enum TechnicianVerificationStatus {
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
}

enum SubscriptionPlan {
  FREE
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_PAYMENT
}

enum RequestUrgency {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ServiceRequestStatus {
  AWAITING_PAYMENT
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  PENDING
  HELD
  RELEASED
  REFUNDED
}

enum ReportReason {
  FAKE_PROFILE
  INAPPROPRIATE_BEHAVIOR
  SCAM
  OFFENSIVE_LANGUAGE
  MISLEADING_CONTENT
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum VerificationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  NEW_MESSAGE
  NEW_REQUEST
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  SERVICE_COMPLETED
  NEW_REVIEW
  TECHNICIAN_VERIFIED
  REPORT_UPDATED
  SYSTEM
}

enum AdminTargetType {
  USER
  TECHNICIAN
  SERVICE_REQUEST
  REVIEW
  REPORT
  CATEGORY
  VERIFICATION
}

enum AdminActionType {
  VERIFY_TECHNICIAN
  REJECT_VERIFICATION
  SUSPEND_USER
  REACTIVATE_USER
  DELETE_REQUEST
  MODERATE_REVIEW
  UPDATE_CATEGORY
  UPDATE_REQUEST_STATUS
  OTHER
}

enum OfferStatus {
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELED
  SUPERSEDED
}

model Role {
  id        String   @id @default(cuid())
  code      RoleCode @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  phone           String?
  birthDate       DateTime?
  isEmailVerified Boolean    @default(false)
  emailVerifiedAt DateTime?
  status          UserStatus @default(ACTIVE)
  roleId          String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  lastLoginAt     DateTime?

  role                  Role                     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  clientProfile         ClientProfile?
  technicianProfile     TechnicianProfile?
  sentMessages          Message[]                @relation("MessageSender")
  chatParticipants      ChatParticipant[]
  serviceRequestsClient ServiceRequest[]         @relation("ServiceRequestClient")
  serviceRequestsTech   ServiceRequest[]         @relation("ServiceRequestTechnician")
  favorites             Favorite[]               @relation("FavoriteClient")
  reviewsWritten        Review[]                 @relation("ReviewClient")
  notifications         Notification[]
  reportsSubmitted      Report[]                 @relation("ReportReporter")
  reportsAgainst        Report[]                 @relation("ReportReportedUser")
  verificationRequested VerificationRequest[]    @relation("VerificationRequestedBy")
  verificationReviewed  VerificationRequest[]    @relation("VerificationReviewedBy")
  adminActions          AdminAction[]            @relation("AdminActionAdmin")
  moderatedReports      Report[]                 @relation("ReportReviewer")
  moderatedReviews      Review[]                 @relation("ReviewModerator")
  verifiedClients       ClientProfile[]          @relation("ClientProfileVerifiedBy")
  verifiedTechnicians   TechnicianProfile[]      @relation("TechnicianProfileVerifiedBy")
  passwordResetTokens   PasswordResetToken[]
  emailVerification     EmailVerificationToken[]
  chatsCreated          Chat[]                   @relation("ChatCreatedBy")
  payments              Payment[]
  offersAsClient        Offer[]                  @relation("OfferClient")

  @@index([roleId])
  @@index([email])
  @@index([status])
}

model ClientProfile {
  id                     String                   @id @default(cuid())
  userId                 String                   @unique
  fullName               String
  city                   String
  zone                   String?
  address                String?
  avatarUrl              String?
  bio                    String?
  identityDocumentNumber String?
  identityDocumentUrl    String?
  verificationStatus     ClientVerificationStatus @default(PENDING)
  rejectionReason        String?
  verificationNote       String?
  verifiedAt             DateTime?
  verifiedById           String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy User? @relation("ClientProfileVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@index([verificationStatus])
}

model TechnicianProfile {
  id                  String                       @id @default(cuid())
  userId              String                       @unique
  displayName         String
  businessName        String?
  city                String
  workZone            String?
  description         String
  yearsExperience     Int                          @default(0)
  availabilityText    String?
  scheduleText        String?
  latitude            Float?
  longitude           Float?
  avatarUrl           String?
  identityDocumentUrl String?
  galleryJson         Json?
  workEvidenceJson    Json?
  certificationsJson  Json?
  policeRecordUrl     String?
  referencePriceMin   Int?
  referencePriceMax   Int?
  isHomeService       Boolean                      @default(true)
  verification        TechnicianVerificationStatus @default(PENDING)
  subscriptionPlan    SubscriptionPlan             @default(FREE)
  subscriptionStatus  SubscriptionStatus           @default(ACTIVE)
  subscriptionStartDate DateTime?
  subscriptionEndDate DateTime?
  autoRenew           Boolean                      @default(false)
  featuredUntil       DateTime?
  lastPaymentDate     DateTime?
  rejectionReason     String?
  verificationNote    String?
  verifiedAt          DateTime?
  verifiedById        String?
  completedJobs       Int                          @default(0)
  averageRating       Float                        @default(0)
  totalReviews        Int                          @default(0)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedBy           User?                 @relation("TechnicianProfileVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  services             TechnicianService[]
  reviews              Review[]
  favorites            Favorite[]
  reportsAgainst       Report[]              @relation("ReportReportedTechnician")
  verificationRequests VerificationRequest[]
  offers               Offer[]

  @@index([city])
  @@index([verification])
  @@index([subscriptionStatus])
  @@index([subscriptionPlan])
  @@index([subscriptionEndDate])
}

model ServiceCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  technicianServices TechnicianService[]
  serviceRequests    ServiceRequest[]
}

model TechnicianService {
  id           String   @id @default(cuid())
  technicianId String
  categoryId   String
  title        String
  description  String?
  basePrice    Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  category   ServiceCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([technicianId, categoryId, title])
  @@index([technicianId])
  @@index([categoryId])
}

model ServiceRequest {
  id                String               @id @default(cuid())
  clientId          String
  technicianId      String?
  categoryId        String
  title             String
  description       String
  city              String
  zone              String?
  locationReference String?
  desiredDate       DateTime?
  urgency           RequestUrgency       @default(MEDIUM)
  budgetMin         Int?
  budgetMax         Int?
  status            ServiceRequestStatus @default(PENDING)
  agreedPrice       Int?
  isDirectRequest   Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  completedAt       DateTime?
  canceledAt        DateTime?

  client     User            @relation("ServiceRequestClient", fields: [clientId], references: [id], onDelete: Cascade)
  technician User?           @relation("ServiceRequestTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  category   ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images     RequestImage[]
  chat       Chat?
  review     Review?
  reports    Report[]
  payment    Payment?
  offers     Offer[]

  @@index([clientId])
  @@index([technicianId])
  @@index([categoryId])
  @@index([city])
  @@index([status])
}

model RequestImage {
  id        String   @id @default(cuid())
  requestId String
  url       String
  caption   String?
  createdAt DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model Chat {
  id               String   @id @default(cuid())
  serviceRequestId String?  @unique
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  serviceRequest ServiceRequest?   @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  createdBy      User              @relation("ChatCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  participants   ChatParticipant[]
  messages       Message[]
  offers         Offer[]

  @@index([createdById])
}

model ChatParticipant {
  id         String    @id @default(cuid())
  chatId     String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id        String    @id @default(cuid())
  chatId    String
  senderId  String
  content   String
  imageUrl  String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  offer  Offer?

  @@index([chatId, createdAt])
  @@index([senderId])
}

model Offer {
  id                  String      @id @default(cuid())
  chatId              String
  serviceRequestId    String?
  messageId           String?     @unique
  clientId            String
  technicianProfileId String
  amount              Decimal     @db.Decimal(12, 2)
  currency            String      @default("NIO")
  description         String?
  status              OfferStatus @default(SENT)
  acceptedAt          DateTime?
  rejectedAt          DateTime?
  canceledAt          DateTime?
  expiresAt           DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  chat              Chat              @relation(fields: [chatId], references: [id], onDelete: Cascade)
  serviceRequest    ServiceRequest?   @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  message           Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  client            User              @relation("OfferClient", fields: [clientId], references: [id], onDelete: Cascade)
  technicianProfile TechnicianProfile @relation(fields: [technicianProfileId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([clientId])
  @@index([technicianProfileId])
  @@index([serviceRequestId])
  @@index([status])
}

model Review {
  id                  String   @id @default(cuid())
  serviceRequestId    String   @unique
  clientId            String
  technicianProfileId String
  rating              Int
  comment             String?
  isModerated         Boolean  @default(false)
  isHidden            Boolean  @default(false)
  moderatedById       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  serviceRequest    ServiceRequest    @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  client            User              @relation("ReviewClient", fields: [clientId], references: [id], onDelete: Cascade)
  technicianProfile TechnicianProfile @relation(fields: [technicianProfileId], references: [id], onDelete: Cascade)
  moderatedBy       User?             @relation("ReviewModerator", fields: [moderatedById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([technicianProfileId])
  @@index([rating])
}

model Favorite {
  id                  String   @id @default(cuid())
  clientId            String
  technicianProfileId String
  createdAt           DateTime @default(now())

  client            User              @relation("FavoriteClient", fields: [clientId], references: [id], onDelete: Cascade)
  technicianProfile TechnicianProfile @relation(fields: [technicianProfileId], references: [id], onDelete: Cascade)

  @@unique([clientId, technicianProfileId])
  @@index([technicianProfileId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  metadata  Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([isRead])
}

model Report {
  id                   String       @id @default(cuid())
  reporterId           String
  reportedUserId       String?
  reportedTechnicianId String?
  serviceRequestId     String?
  reason               ReportReason
  details              String
  status               ReportStatus @default(OPEN)
  reviewedById         String?
  resolutionNote       String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  reviewedAt           DateTime?

  reporter           User               @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser       User?              @relation("ReportReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reportedTechnician TechnicianProfile? @relation("ReportReportedTechnician", fields: [reportedTechnicianId], references: [id], onDelete: SetNull)
  serviceRequest     ServiceRequest?    @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  reviewedBy         User?              @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([reportedTechnicianId])
  @@index([status])
}

model VerificationRequest {
  id                  String                    @id @default(cuid())
  technicianProfileId String
  requestedById       String
  documentUrl         String?
  notes               String?
  status              VerificationRequestStatus @default(PENDING)
  reviewedById        String?
  reviewNote          String?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  reviewedAt          DateTime?

  technicianProfile TechnicianProfile @relation(fields: [technicianProfileId], references: [id], onDelete: Cascade)
  requestedBy       User              @relation("VerificationRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedBy        User?             @relation("VerificationReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([technicianProfileId])
  @@index([status])
}

model AdminAction {
  id         String          @id @default(cuid())
  adminId    String
  actionType AdminActionType
  targetType AdminTargetType
  targetId   String
  details    Json?
  createdAt  DateTime        @default(now())

  admin User @relation("AdminActionAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([targetType, targetId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Payment {
  id               String        @id @default(cuid())
  serviceRequestId String        @unique
  clientId         String
  amount           Int
  status           PaymentStatus @default(PENDING)
  cardLastFour     String?
  cardHolder       String?
  paidAt           DateTime?
  releasedAt       DateTime?
  refundedAt       DateTime?
  refundReason     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  client         User           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}
