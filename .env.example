# Base de datos (recomendado para Supabase + Prisma)
# DATABASE_URL se usa en la app (pooler 6543 con pgbouncer)
# En desarrollo usa connection_limit=10 para soportar pruebas simultáneas por rol.
# DIRECT_URL se usa para migraciones (puerto directo 5432)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require&connection_limit=10"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Alternativa local (sin Supabase):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/certitech?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/certitech?schema=public"

# URL publica de la aplicacion
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Secrets para sesiones JWT
JWT_ACCESS_SECRET="cambia-este-access-secret-muy-largo"
JWT_REFRESH_SECRET="cambia-este-refresh-secret-muy-largo"

# Configuracion de correo (recuperacion/verificacion)
EMAIL_PROVIDER="console"
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="CertiTech <no-reply@certitech.app>"
RESEND_API_KEY=""

# Almacenamiento de imagenes (local o cloudinary)
UPLOAD_PROVIDER="local"
UPLOAD_LOCAL_PATH="public/uploads"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Integraciones opcionales
GOOGLE_MAPS_API_KEY=""

